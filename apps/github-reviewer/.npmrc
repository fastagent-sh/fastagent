; @kid7st/fastagent is on GitHub Packages. Token comes from the GITHUB_TOKEN env var
; (never commit the token): locally `export GITHUB_TOKEN=$(gh auth token)`, in the
; Docker build via `--build-secret GITHUB_TOKEN=…` (see Dockerfile).
@kid7st:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
