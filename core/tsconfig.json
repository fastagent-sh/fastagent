{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true
  },
  "include": ["src", "test"],
  // Scaffold payload: real template files copied verbatim into a new workspace. They import the
  // published @kid7st/fastagent (not this source), so they are data here, not part of the build.
  "exclude": ["src/engines/pi/scaffold/templates"]
}
