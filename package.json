{
  "name": "@fastagent-sh/fastagent",
  "version": "0.12.1",
  "description": "Vibe first. Then FastAgent: turn a local agent directory into a live service in your app, on GitHub, in Telegram, or behind any channel.",
  "keywords": [
    "agent",
    "ai-agent",
    "llm",
    "agents.md",
    "agent-skills",
    "agent-serving",
    "telegram",
    "github",
    "webhook",
    "sse",
    "pi",
    "fastagent"
  ],
  "license": "MIT",
  "author": "the fastagent authors (https://github.com/fastagent-sh/fastagent)",
  "homepage": "https://fastagent.sh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fastagent-sh/fastagent.git"
  },
  "bugs": {
    "url": "https://github.com/fastagent-sh/fastagent/issues"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22.19.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "default": "./dist/core.js"
    },
    "./pi": {
      "types": "./dist/pi.d.ts",
      "default": "./dist/pi.js"
    },
    "./github": {
      "types": "./dist/github.d.ts",
      "default": "./dist/github.js"
    },
    "./telegram": {
      "types": "./dist/telegram.d.ts",
      "default": "./dist/telegram.js"
    },
    "./feishu": {
      "types": "./dist/feishu.d.ts",
      "default": "./dist/feishu.js"
    },
    "./lark": {
      "types": "./dist/lark.d.ts",
      "default": "./dist/lark.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "fastagent": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src test && node scripts/check-doc-links.mjs",
    "format": "biome check --write src test",
    "postbuild": "node scripts/copy-scaffold-assets.mjs"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "@earendil-works/pi-agent-core": "^0.80.3",
    "@earendil-works/pi-ai": "^0.80.3",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@octokit/webhooks-methods": "^6.0.0",
    "@octokit/webhooks-types": "^7.6.1",
    "chokidar": "^5.0.0",
    "croner": "^10.0.1",
    "giget": "^3.3.0",
    "ignore": "^7.0.5",
    "undici": "^8.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  }
}
